APP_ENV=dev
APP_NAME=domainforge

# LLM
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
FALLBACK_LLM_PROVIDER=
FALLBACK_LLM_MODEL=
# 可用模型列表（逗号分隔），供 agent 表单下拉；为空则回退到 [DEFAULT_LLM_MODEL]
AVAILABLE_MODELS=

# Embedding
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY=

# Database
DATABASE_URL=postgresql+asyncpg://domainforge:domainforge@localhost:5432/domainforge

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=true

# Observability
OTEL_SERVICE_NAME=domainforge
OTEL_EXPORTER_OTLP_ENDPOINT=

# Security
# 生产必填：32+ 字节随机串，用 `openssl rand -hex 32` 生成。
# APP_ENV=prod 时若仍为默认值或 <32 字节，启动会失败（除非 JWT_SECRET_OVERRIDE=true 紧急跳过）。
JWT_SECRET=change-me-in-production
JWT_SECRET_OVERRIDE=false
ADMIN_API_KEY=

# CORS：逗号分隔的允许 origin 列表，生产应收紧到具体域名
CORS_ORIGINS=http://localhost:3000
